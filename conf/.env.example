# --- Project name –-- #
COMPOSE_PROJECT_NAME=llm_serving


# --- Model Configuration (update all three when switching models) --- #

# Full HuggingFace model path (used by vLLM to download and load the model weights)
HF_MODEL_ID=nvidia/Gemma-4-31B-IT-NVFP4

# Short model name used in API requests and as the vLLM served-model name
MODEL_NAME=gemma-4-31b-nvfp4

# LiteLLM routing key – must always be "openai/" + MODEL_NAME for vLLM backends
LITELLM_MODEL=openai/gemma-4-31b-nvfp4


# --- Authentication Tokens and API Keys --- #
# Generate Keys with: python3 -c "import secrets; print('vllm-' + secrets.token_urlsafe(32))"

# HuggingFace token (required for gated models; accept the target model license first)
HF_TOKEN=

# LiteLLM master API key (clients use this to authenticate)
LITELLM_MASTER_KEY=

# vLLM internal API key (defense-in-depth: authenticates LiteLLM → vLLM traffic)
VLLM_API_KEY=


# --- vLLM Inference Parameters --- #

# Weight and activation data type (auto, float16, bfloat16, float32)
VLLM_DTYPE=auto

# Quantization: set to "--quantization <method>" to enable, leave empty to disable.
# Supported methods: nvfp4, awq, gptq, fp8, bitsandbytes, marlin, squeezellm, ...
# The variable encodes both the flag and the type so that leaving it empty
# cleanly disables quantization (Docker Compose cannot nest variable expansions).
VLLM_QUANTIZATION_ARG=--quantization nvfp4

# Maximum sequence length (prompt + generation tokens); lower values reduce VRAM usage
VLLM_MAX_MODEL_LEN=8192

# Maximum total tokens across all concurrent requests in one scheduler step
VLLM_MAX_NUM_BATCHED_TOKENS=8192

# Maximum number of sequences processed concurrently; affects throughput vs. latency
VLLM_MAX_NUM_SEQS=256

# Fraction of GPU HBM reserved for the KV cache (0.0–1.0)
VLLM_GPU_MEMORY_UTILIZATION=0.82

# Tensor parallelism: set to "--tensor-parallel-size <n>" for multi-GPU, leave empty for single-GPU.
# Also increase VLLM_SHM_SIZE proportionally (e.g. 32g for 2 GPUs, 64g for 4 GPUs).
VLLM_TENSOR_PARALLEL_ARG=

# Prefix caching: set to "--enable-prefix-caching" to enable, leave empty to disable
VLLM_ENABLE_PREFIX_CACHING=--enable-prefix-caching

# Shared memory size for NCCL inter-GPU communication; scale with tensor parallelism degree
VLLM_SHM_SIZE=16g


# --- LiteLLM Gateway Parameters --- #

# Number of Uvicorn worker processes (increase for higher request concurrency)
LITELLM_NUM_WORKERS=2
