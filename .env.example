# --- Project name –-- #
COMPOSE_PROJECT_NAME=llm_serving


# --- Model Configuration (update all three when switching models) --- #

# Full HuggingFace model path (used by vLLM to download and load the model weights)
HF_MODEL_ID=nvidia/Gemma-4-31B-IT-NVFP4

# Short model name used in API requests and as the vLLM served-model name
MODEL_NAME=gemma-4-31b-nvfp4

# LiteLLM routing key – must always be "openai/" + MODEL_NAME for vLLM backends
LITELLM_MODEL=openai/gemma-4-31b-nvfp4


# --- Authentication Tokens and API Keys --- #
# Generate Keys with: python3 -c "import secrets; print('vllm-' + secrets.token_urlsafe(32))"

# HuggingFace token (required – accept the model licence at https://huggingface.co/nvidia/Gemma-4-31B-IT-NVFP4)
HF_TOKEN=

# LiteLLM master API key (clients use this to authenticate)
LITELLM_MASTER_KEY=

# vLLM internal API key (defense-in-depth: authenticates LiteLLM → vLLM traffic)
VLLM_API_KEY=
